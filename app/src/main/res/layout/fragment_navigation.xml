<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/btnCallbacks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Коллбэки" />

    <Button
        android:id="@+id/btnEventBus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Шина событий" />

    <Button
        android:id="@+id/btnIntentFlags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Intent флаги" />

    <Button
        android:id="@+id/btnBackStack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Бэкстек фрагментов" />

</LinearLayout>